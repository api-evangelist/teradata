{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/teradata/refs/heads/main/json-structure/query-service-api-session-structure.json",
  "name": "Session",
  "description": "A query session.",
  "type": "object",
  "properties": {
    "sessionId": { "type": "string", "description": "Unique session identifier." },
    "system": { "type": "string", "description": "Connected system name." },
    "database": { "type": "string", "description": "Default database." },
    "status": { "type": "string", "description": "Session status.", "enum": ["active", "idle", "closed"] },
    "createdAt": { "type": "datetime", "description": "Session creation time." }
  }
}
